# ============================================
# Configuration - Cloudflare Access HR Directory
# ============================================

# ID du projet GCP (obligatoire)
project_id = "ton-projet-gcp"

# Votre IP publique pour restreindre l'accès SSH (optionnel)
# Par défaut: 0.0.0.0/0 (SSH ouvert à toutes les IP - moins sécurisé mais pratique)
# Pour plus de sécurité, spécifiez votre IP: trouvez-la sur https://www.whatismyip.com/
# my_ip = "1.2.3.4"

# Clé SSH publique (obligatoire)
# Générez-la avec : ssh-keygen -t ed25519 -C "david@mac"
ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAID... david@mac"

# Token du tunnel Cloudflare (optionnel mais recommandé)
# Permet la configuration automatique du tunnel sans connexion SSH
# 1. Créez un tunnel dans Cloudflare One: https://one.dash.cloudflare.com → Networks → Tunnels
# 2. Nommez-le: "hr-directory-tunnel"
# 3. Copiez le token fourni et collez-le ici:
# cloudflare_tunnel_token = "eyJhY2NvdW50SUQiOiIxMjM0NTY3ODkiLCJ0dW5uZWxJRCI6ImFiY2QtZWZnaCIsInNlY3JldCI6Inh4eHh4eCJ9"

# Optionnel : personnalisez les noms si nécessaire
# access_instance_name = "vm-access-hr-directory"
# access_vpc_name = "access-vpc"
# access_subnet_name = "access-subnet"
# access_firewall_name = "access-allow-ssh"
